/dts-v1/;

#include <espressif/esp32s3/esp32s3_wroom_n8.dtsi>

/ {
    model = "Our Board Scratch;
    compatible = "iomico,our-board-scratch";
    aliases {
        app-led = &led0;
    };

    chosen {
        zephyr,sram = &sram1;
        zephyr,flash = &flash0;
        zephyr,code-partition = &slot0_partition;
    };

    leds {
        compatible = "gpio-leds";
        led0: led_0 {
            gpios = <&gpio0 48 GPIO_ACTIVE_HIGH>; //GPIO 48
            label = "LED 0";
        };
    };
};

&gpio0 {
    status = "okay";
};

