menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default n

if LED_SUBSYSTEM
    config APP_HEARTBEAT_PERIOD_MS
    	int "App Heartbeat period (100-2000)ms"
    	default 500
    	range 100 2000

    choice
        prompt "LED blink sleep time"
        default BLINK_SLEEP_1000MS

    config BLINK_SLEEP_250MS
        bool "250ms (very fast)"

    config BLINK_SLEEP_500MS
        bool "500ms (fast)"

    config BLINK_SLEEP_1000MS
        bool "1s (medium)"

    config BLINK_SLEEP_2000MS
        bool "2s (slow)"
    endchoice

    config BLINK_SLEEP_TIME_MS
        int
        depends on BLINK_SLEEP_250MS || BLINK_SLEEP_500MS || BLINK_SLEEP_1000MS || BLINK_SLEEP_2000MS
        default 250  if BLINK_SLEEP_250MS
        default 500  if BLINK_SLEEP_500MS
        default 1000 if BLINK_SLEEP_1000MS
        default 2000 if BLINK_SLEEP_2000MS
        default 0

    menuconfig ADVANCED_LED_SETTINGS
        bool "Advanced LED settings"
        default n

    if ADVANCED_LED_SETTINGS

        config LED_BRIGHTNESS
            int "LED brightness (0-100)"
            default 100
            range 0 100
            help
                Set the LED brightness level (0-100%)
    
        config LED_FADE_DURATION_MS
            int "LED fade duration (ms)"
            default 500
            range 0 5000
            help
                Set the duration for LED fade in/out effects in milliseconds

        menu "Expert settings"
            visible if ADVANCED_LED_SETTINGS
            config ENABLE_LED_DEBUGGING
                bool "Enable LED debugging"
                default n
                help
                    Enable debug output for LED operations (not recommended for production)

            config CUSTOM_LED_PATTERN
                bool "Custom blink pattern"
                default n
                help
                    Define a custom LED blinking pattern.
        endmenu #Expert settings
        
    endif #ADVANCED_LED_SETTINGS
endif #LED_SUBSYSTEM

source "Kconfig.zephyr"
